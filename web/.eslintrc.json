{
  "root": true,
  "extends": ["next/core-web-vitals", "plugin:@typescript-eslint/recommended", "prettier"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "no-unused-vars": "off",
    "react-hooks/exhaustive-deps": "warn",
    "react/no-unescaped-entities": "warn",
    "@next/next/no-img-element": "warn"
  },
  "overrides": [
    {
      "files": [
        "src/components/CommentRow.tsx",
        "src/components/CommentThread.tsx",
        "src/components/CommentComposer.tsx",
        "src/components/ConfirmDialog.tsx",
        "src/components/LockModal.tsx",
        "src/components/article/ArticleSurface.tsx",
        "src/components/article/StoryEditor.tsx",
        "src/components/welcome/WelcomeModal.tsx",
        "src/components/family/AddKidUpsellModal.tsx",
        "src/app/_home/HomeLayout.tsx",
        "src/app/leaderboard/page.tsx",
        "src/app/profile/kids/page.tsx",
        "src/app/u/[username]/page.tsx"
      ],
      "rules": {
        "no-restricted-syntax": [
          "warn",
          {
            "selector": "Property[key.name='borderRadius'] > Literal[value=/\\d+px/]",
            "message": "Use var(--r-sm/md/lg/xl/pill) tokens instead of hardcoded pixel strings. Tag intentional off-grid with `// eslint-disable-next-line no-restricted-syntax -- magic, intentional`."
          },
          {
            "selector": "Property[key.name='padding'] > Literal[value=/\\d+px/]",
            "message": "Use var(--s0..--s10) tokens instead of hardcoded pixel strings. Tag intentional off-grid with `// eslint-disable-next-line no-restricted-syntax -- magic, intentional`."
          }
        ]
      }
    }
  ],
  "ignorePatterns": [
    "node_modules",
    ".next",
    "src/types/database.ts",
    "next-env.d.ts",
    "*.tsbuildinfo"
  ]
}
