# Copy to .env.local and fill in real values. DO NOT commit .env.local.
# .gitignore already excludes it.
#
# All of these need to be set in Vercel (Production + Preview) too — the
# set in .env.local is JUST for local dev. Any var read by code that is
# missing from Vercel env ships a silently-broken surface.

# --- Supabase (required) ---
# Project URL — public, OK to commit in .env.example.
NEXT_PUBLIC_SUPABASE_URL=https://fyiwulqphgmoqullmrfn.supabase.co

# Anon key — public-by-design. Grab from Supabase dashboard → Settings → API → anon public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — rotated 2026-04-20. Grab the CURRENT value from Supabase dashboard → Settings → API → service_role. NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used to mint the custom kid JWT at /api/kids/pair. Same dashboard page.
SUPABASE_JWT_SECRET=

# --- Stripe (required for billing flows) ---
# Rotated 2026-04-20. For local dev use sk_test_...; prod uses sk_live_... in Vercel env.
STRIPE_SECRET_KEY=

# Webhook signing secret. Also rotated 2026-04-20. Use the value for the endpoint you're hitting locally.
STRIPE_WEBHOOK_SECRET=

# --- Stripe price IDs (OPTIONAL — currently unused by code) ---
# The 8 entries below were originally intended to hold Stripe price IDs in
# env, but the codebase reads them from `plans.stripe_price_id` in the DB
# instead (the DB is already populated). Nothing reads these env vars as of
# 2026-04-20. Kept here commented so the history isn't lost and the names
# stay reserved in case a future migration moves the source of truth.
# STRIPE_PRICE_VERITY_MONTHLY=
# STRIPE_PRICE_VERITY_ANNUAL=
# STRIPE_PRICE_VERITY_PRO_MONTHLY=
# STRIPE_PRICE_VERITY_PRO_ANNUAL=
# STRIPE_PRICE_VERITY_FAMILY_MONTHLY=
# STRIPE_PRICE_VERITY_FAMILY_ANNUAL=
# STRIPE_PRICE_VERITY_FAMILY_XL_MONTHLY=
# STRIPE_PRICE_VERITY_FAMILY_XL_ANNUAL=

# --- Resend (emails) ---
RESEND_API_KEY=
EMAIL_FROM=no-reply@veritypost.com

# --- Cron auth (any 32-byte random string) ---
# Generate locally: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=

# --- Health check ---
# Secret for the privileged branch of /api/health that returns DB + queue
# detail. Optional — unset means the endpoint only returns the public
# shallow status. Use the same 32-byte generator as CRON_SECRET above.
HEALTH_CHECK_SECRET=

# --- APNs (iOS push) ---
APNS_AUTH_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.veritypost.app
APNS_ENV=sandbox
# APNS topic (push bundle) — defaults to 'com.veritypost.app' in code. Only
# set if you ever need to push to a non-default topic.
# APNS_TOPIC=com.veritypost.app

# --- Apple App Store (IAP receipt verification) ---
APPSTORE_SHARED_SECRET=
# Base64-encoded Apple root CA cert (DER). Required for signed-transaction
# JWS verification in src/lib/appleReceipt.js. Grab from Apple's PKI page
# and base64 it. Set in Vercel Production.
APPLE_ROOT_CA_DER_BASE64=

# --- OpenAI (AI-generate route) ---
OPENAI_API_KEY=

# --- Site URL (for email links, OAuth callbacks, absolute OG URLs) ---
# `https://veritypost.com` in prod. Any metadata/email that builds an
# absolute URL reads this — wrong value = broken shares + broken email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Pre-launch holding mode ---
# When set to `coming_soon`, middleware redirects all public routes to
# /welcome (which renders a minimal brand card) and sets X-Robots-Tag
# noindex. Unset / any other value = normal site behaviour.
# NEXT_PUBLIC_SITE_MODE=coming_soon

# Token for /preview?token=<value> — sets a 30-day `vp_preview=ok` cookie
# that bypasses coming_soon mode. Any 32-byte random string works; same
# generator as CRON_SECRET. Only meaningful when SITE_MODE=coming_soon.
PREVIEW_BYPASS_TOKEN=

# --- Sentry (error reporting) ---
# DSN for server-side SDK (instrumentation.ts). Production build in
# next.config.js refuses to build without Sentry, so this is effectively
# required in Vercel prod env.
SENTRY_DSN=
# DSN for browser SDK (sentry.client.config.js). Usually the same value
# as SENTRY_DSN, exposed to the client via NEXT_PUBLIC_* prefix.
NEXT_PUBLIC_SENTRY_DSN=
# Org + project slugs + auth token for the @sentry/nextjs build step that
# uploads sourcemaps. Without these, runtime errors show as minified
# stacktraces in Sentry.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Vercel-injected (don't set manually, noted for reference) ---
# Vercel sets these automatically on deploys. Code reads them for release
# tagging in Sentry.
# NEXT_PUBLIC_VERCEL_ENV=
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
